# ============================================
# Database / 数据库
# ============================================

# Neon Postgres 或本地 Postgres 连接串。
# - 本地 Postgres (Docker) 示例：postgresql://postgres:postgres@localhost:5432/zhaoming?sslmode=disable
# - 本地开发如果接远程 Neon，也直接填这里。
DATABASE_URL=


# ============================================
# Auth / 鉴权
# ============================================

# Better Auth 使用的服务端密钥。
# 至少 32 位，建议使用高强度随机字符串（本地开发可运行 `openssl rand -hex 32` 生成）。
BETTER_AUTH_SECRET=

# 当前应用对外访问地址。
# 本地开发默认使用 http://localhost:5555
# 生产环境请填写正式域名，例如 https://www.zhaoming.app
BETTER_AUTH_URL=http://localhost:5555

# 线上或通用 Google OAuth 凭据。
# 回调地址通常需要包含：/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 登录系统模式：
# - oauth: 同时支持 Google OAuth 和邮箱密码登录
# - credentials: 仅支持邮箱密码登录（不需要配置 Google OAuth）
# - none: 免登录游客模式（所有用户共享一个游客账号，直接进入工作台）
# 默认值：如果配置了 GOOGLE_CLIENT_ID & GOOGLE_CLIENT_SECRET 则为 oauth，否则为 credentials
NEXT_PUBLIC_AUTH_MODE=


# ============================================
# AI / 大模型
# ============================================

# AI Provider 类型：
# - gateway
# - openai-compatible
# 当前 README 推荐使用 openai-compatible
AI_PROVIDER=openai-compatible

# 模型名。
# 示例使用 README 当前推荐值 (OpenRouter 格式)。
# 常见提供商与模型示例：
# - OpenRouter: ~google/gemini-flash-latest 或 deepseek/deepseek-chat
# - DeepSeek 官方: deepseek-chat
# - OpenAI 官方: gpt-4o-mini
AI_MODEL=~google/gemini-flash-latest

# OpenAI 兼容接口的 Base URL。
# 常见提供商 Base URL 示例：
# - OpenRouter: https://openrouter.ai/api/v1
# - DeepSeek 官方: https://api.deepseek.com/v1
# - OpenAI 官方: https://api.openai.com/v1
# 如果 AI_PROVIDER=gateway，可按你的网关配置调整。
AI_BASE_URL=https://openrouter.ai/api/v1

# AI 平台 API Key。
# 填入对应平台的 API Key。
AI_API_KEY=


# ============================================
# Automation / 自动化发布
# ============================================

# 保护 /api/automation/publish-blog 接口的密钥。
# 调用方需要通过 Authorization Bearer 或 x-automation-key 传入相同值。
AUTOMATION_API_KEY=


# ============================================
# Billing / 支付
# ============================================

# 是否启用支付功能。开源版默认关闭，只有配置完整支付服务后再改为 true。
BILLING_ENABLED=false

# 当前支付提供商
# - stripe
BILLING_PROVIDER=stripe

# Stripe 服务端密钥（沙盒以 sk_test_ 开头）
STRIPE_SECRET_KEY=

# Stripe Checkout / Elements 的前端公开 key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Webhook 签名密钥（以 whsec_ 开头）
STRIPE_WEBHOOK_SECRET=

# Stripe 价格 ID
STRIPE_PRICE_SINGLE_REPORT=
STRIPE_PRICE_STARTER_PACK=
STRIPE_PRICE_POPULAR_PACK=
STRIPE_PRICE_DEEP_DIVE_PACK=
