# ============================================
# Database / 数据库
# ============================================

# Neon Postgres 连接串。
# 本地开发如果接远程 Neon，也直接填这里。
DATABASE_URL=


# ============================================
# Auth / 鉴权
# ============================================

# Better Auth 使用的服务端密钥。
# 至少 32 位，建议使用高强度随机字符串。
BETTER_AUTH_SECRET=

# 当前应用对外访问地址。
# 本地开发默认使用 http://localhost:5555
# 生产环境请填写正式域名，例如 https://zhaoming.app
BETTER_AUTH_URL=http://localhost:5555

# 线上或通用 Google OAuth 凭据。
# 回调地址通常需要包含：/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ============================================
# AI / 大模型
# ============================================

# AI Provider 类型：
# - gateway
# - openai-compatible
# 当前 README 推荐使用 openai-compatible
AI_PROVIDER=openai-compatible

# 模型名。
# 示例使用 README 当前推荐值。
AI_MODEL=deepseek/deepseek-v4-pro

# OpenAI 兼容接口的 Base URL。
# 如果使用 OpenRouter，可填写 https://openrouter.ai/api/v1
# 如果 AI_PROVIDER=gateway，可按你的网关配置调整。
AI_BASE_URL=https://openrouter.ai/api/v1

# AI 平台 API Key。
# 使用 OpenRouter 时填写对应的 key。
AI_API_KEY=


# ============================================
# Automation / 自动化发布
# ============================================

# 保护 /api/automation/publish-blog 接口的密钥。
# 调用方需要通过 Authorization Bearer 或 x-automation-key 传入相同值。
AUTOMATION_API_KEY=


# ============================================
# Billing / 支付
# ============================================

# 当前支付提供商
# - stripe
# - paddle
BILLING_PROVIDER=stripe

# Stripe 服务端密钥（沙盒以 sk_test_ 开头）
STRIPE_SECRET_KEY=

# Stripe Checkout / Elements 的前端公开 key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Webhook 签名密钥（以 whsec_ 开头）
STRIPE_WEBHOOK_SECRET=

# Stripe 价格 ID
STRIPE_PRICE_SINGLE_REPORT=
STRIPE_PRICE_STARTER_PACK=
STRIPE_PRICE_POPULAR_PACK=
STRIPE_PRICE_DEEP_DIVE_PACK=


# ============================================
# Paddle / 支付
# ============================================

# Paddle 服务端 API Key
PADDLE_API_KEY=

# Paddle Checkout 前端 Client-side Token
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=

# Paddle Webhook 签名密钥
PADDLE_WEBHOOK_SECRET=

# Paddle 环境
# - sandbox
# - production
PADDLE_ENVIRONMENT=sandbox

# Paddle 价格 ID（以 pri_ 开头）
PADDLE_PRICE_SINGLE_REPORT=
PADDLE_PRICE_POPULAR_PACK=
PADDLE_PRICE_DEEP_DIVE_PACK=
